@model BillingSystem.Models.InvoiceDetail

@{
    ViewBag.Title = "Edit Invoice Item";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Details", "Invoices", new { id = Model.InvoiceId })">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Invoice Items</div>
        <h1 class="page-title"><span>Edit</span> item settings</h1>
    </div>
    <div style="min-width:120px;"></div>
</div>

@using (Html.BeginForm("Edit", "InvoiceDetails", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.InvoiceDetailId)
    @Html.HiddenFor(m => m.InvoiceId)

    <div class="form-page-card">
        <div class="form-page-header">
            <i class="fa fa-circle-info"></i> Item Information
        </div>

        @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

        <div class="form-row-grid">
            <div class="float-field">
                <label>InvoiceDetailId</label>
                <input class="float-input" value="@Model.InvoiceDetailId" readonly />
            </div>
            <div class="float-field" style="grid-column:span 2;">
                <label>ProductName</label>
                @Html.TextBoxFor(m => m.ProductName, new { @class = "float-input", placeholder = " " })
                @Html.ValidationMessageFor(m => m.ProductName, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Quantity</label>
                @Html.TextBoxFor(m => m.Quantity, new { @class = "float-input", type = "number", min = "1", placeholder = " " })
                @Html.ValidationMessageFor(m => m.Quantity, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>UnitPrice</label>
                @Html.TextBoxFor(m => m.UnitPrice, new { @class = "float-input", type = "number", step = "0.01", placeholder = " " })
                @Html.ValidationMessageFor(m => m.UnitPrice, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>SubTotal (computed)</label>
                <input class="float-input" value="@(Model.SubTotal.HasValue ? String.Format("{0:C}", Model.SubTotal) : "-")" readonly />
            </div>
        </div>

        <div class="form-page-actions">
            <button type="submit" class="btn-create">
                <i class="fa fa-floppy-disk"></i> SAVE
            </button>
            <a href="@Url.Action("Details", "Invoices", new { id = Model.InvoiceId })" class="btn-back" style="margin-left:10px;">
                Cancel
            </a>
        </div>
    </div>
}
