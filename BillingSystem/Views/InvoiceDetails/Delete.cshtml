@model BillingSystem.Models.InvoiceDetail

@{
    ViewBag.Title = "Delete Item";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Details", "Invoices", new { id = Model.InvoiceId })">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Invoice Items</div>
        <h1 class="page-title" style="color:#e8304a;"><span style="color:#e8304a;">Delete</span> item?</h1>
    </div>
    <div style="min-width:120px;"></div>
</div>

<div class="form-page-card" style="border-top:4px solid #e8304a;">
    <div class="form-page-header" style="color:#e8304a;border-color:#fde8ec;">
        <i class="fa fa-triangle-exclamation"></i> Confirm Deletion
    </div>
    <p style="color:#7a8a99;font-size:14px;margin-bottom:22px;">
        Are you sure you want to delete this item? This action cannot be undone.
    </p>

    <div class="form-row-grid">
        <div class="float-field">
            <label>InvoiceDetailId</label>
            <input class="float-input" value="@Model.InvoiceDetailId" readonly />
        </div>
        <div class="float-field" style="grid-column:span 2;">
            <label>ProductName</label>
            <input class="float-input" value="@Model.ProductName" readonly />
        </div>
        <div class="float-field">
            <label>Quantity</label>
            <input class="float-input" value="@Model.Quantity" readonly />
        </div>
        <div class="float-field">
            <label>UnitPrice</label>
            <input class="float-input" value="@String.Format("{0:C}", Model.UnitPrice)" readonly />
        </div>
        <div class="float-field">
            <label>SubTotal</label>
            <input class="float-input" value="@(Model.SubTotal.HasValue ? String.Format("{0:C}", Model.SubTotal) : "-")" readonly />
        </div>
    </div>

    @using (Html.BeginForm("Delete", "InvoiceDetails", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.InvoiceDetailId)
        <div class="form-page-actions">
            <button type="submit" class="btn-create" style="background:#e8304a;box-shadow:0 4px 12px rgba(232,48,74,.30);">
                <i class="fa fa-trash"></i> YES, DELETE
            </button>
            <a href="@Url.Action("Details", "Invoices", new { id = Model.InvoiceId })" class="btn-back" style="margin-left:10px;">
                Cancel
            </a>
        </div>
    }
</div>
