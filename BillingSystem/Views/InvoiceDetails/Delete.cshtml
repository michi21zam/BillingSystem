@model BillingSystem.Models.InvoiceDetail

@{
    ViewBag.Title = "Delete";
}

<h2>Delete</h2>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>InvoiceDetail</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Product Name</dt>
        <dd>@Html.DisplayFor(model => model.ProductName)</dd>

        <dt>Quantity</dt>
        <dd>@Html.DisplayFor(model => model.Quantity)</dd>

        <dt>Unit Price</dt>
        <dd>@Html.DisplayFor(model => model.UnitPrice)</dd>

        <dt>Subtotal</dt>
        <dd>@Html.DisplayFor(model => model.SubTotal)</dd>

        <dt>Invoice Number</dt>
        <dd>@Html.DisplayFor(model => model.Invoice.InvoiceNumber)</dd>
    </dl>

    @using (Html.BeginForm()) {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.InvoiceDetailId)

        <div class="form-actions no-color">
            <input type="submit" value="Delete" class="btn btn-default" /> |
            @Html.ActionLink("Back to List", "Index", "Invoices")
        </div>
    }
</div>
