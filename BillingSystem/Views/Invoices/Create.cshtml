@model BillingSystem.Models.Invoice

@{
    ViewBag.Title = "Create Invoice";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Index", "Invoices")">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Invoices</div>
        <h1 class="page-title"><span>Create</span> new invoice</h1>
    </div>
    <div style="min-width:120px;"></div>
</div>

@using (Html.BeginForm("Create", "Invoices", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-page-card">
        <div class="form-page-header">
            <i class="fa fa-circle-info"></i> Invoice Information
        </div>

        @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

        <div class="form-row-grid">
            <div class="float-field">
                <label>InvoiceNumber</label>
                @Html.TextBoxFor(m => m.InvoiceNumber, new { @class = "float-input", placeholder = " " })
                @Html.ValidationMessageFor(m => m.InvoiceNumber, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>InvoiceDate</label>
                @Html.TextBoxFor(m => m.InvoiceDate, "{0:yyyy-MM-ddTHH:mm}", new { @class = "float-input", type = "datetime-local", placeholder = " " })
                @Html.ValidationMessageFor(m => m.InvoiceDate, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>CustomerName</label>
                @Html.TextBoxFor(m => m.CustomerName, new { @class = "float-input", placeholder = " " })
                @Html.ValidationMessageFor(m => m.CustomerName, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>TotalAmount</label>
                @Html.TextBoxFor(m => m.TotalAmount, new { @class = "float-input", type = "number", step = "0.01", placeholder = " " })
                @Html.ValidationMessageFor(m => m.TotalAmount, "", new { @class = "field-error" })
            </div>
        </div>

        @Html.HiddenFor(m => m.IsActive)

        <div class="form-page-actions">
            <button type="submit" class="btn-create">
                <i class="fa fa-floppy-disk"></i> SAVE
            </button>
            <a href="@Url.Action("Index", "Invoices")" class="btn-back" style="margin-left:10px;">
                Cancel
            </a>
        </div>
    </div>
}
