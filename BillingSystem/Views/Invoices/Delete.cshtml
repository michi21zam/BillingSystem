@model BillingSystem.Models.Invoice

@{
    ViewBag.Title = "Delete";
}

<h2>Delete</h2>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Invoice</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Invoice Number</dt>
        <dd>@Html.DisplayFor(model => model.InvoiceNumber)</dd>

        <dt>Invoice Date</dt>
        <dd>@Html.DisplayFor(model => model.InvoiceDate)</dd>

        <dt>Customer Name</dt>
        <dd>@Html.DisplayFor(model => model.CustomerName)</dd>

        <dt>Total Amount</dt>
        <dd>@Html.DisplayFor(model => model.TotalAmount)</dd>



    </dl>

    @using (Html.BeginForm()) {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.InvoiceId)

        <div class="form-actions no-color">
            <input type="submit" value="Delete" class="btn btn-default" /> |
            @Html.ActionLink("Back to List", "Index")
        </div>
    }
</div>
