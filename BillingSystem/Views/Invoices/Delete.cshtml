@model BillingSystem.Models.Invoice

@{
    ViewBag.Title = "Delete Invoice";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Index", "Invoices")">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Invoices</div>
        <h1 class="page-title" style="color:#e8304a;"><span style="color:#e8304a;">Delete</span> invoice?</h1>
    </div>
    <div style="min-width:120px;"></div>
</div>

<div class="form-page-card" style="border-top:4px solid #e8304a;">
    <div class="form-page-header" style="color:#e8304a;border-color:#fde8ec;">
        <i class="fa fa-triangle-exclamation"></i> Confirm Deletion
    </div>
    <p style="color:#7a8a99;font-size:14px;margin-bottom:22px;">
        Are you sure you want to delete the following invoice? This action cannot be undone.
    </p>

    <div class="form-row-grid">
        <div class="float-field">
            <label>InvoiceId</label>
            <input class="float-input" value="@Model.InvoiceId" readonly />
        </div>
        <div class="float-field">
            <label>InvoiceNumber</label>
            <input class="float-input" value="@Model.InvoiceNumber" readonly />
        </div>
        <div class="float-field">
            <label>InvoiceDate</label>
            <input class="float-input" value="@Model.InvoiceDate.ToString("MMM dd, yyyy HH:mm")" readonly />
        </div>
        <div class="float-field">
            <label>CustomerName</label>
            <input class="float-input" value="@Model.CustomerName" readonly />
        </div>
        <div class="float-field">
            <label>TotalAmount</label>
            <input class="float-input" value="@String.Format("{0:C}", Model.TotalAmount)" readonly />
        </div>
    </div>

    @using (Html.BeginForm("Delete", "Invoices", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.InvoiceId)
        <div class="form-page-actions">
            <button type="submit" class="btn-create" style="background:#e8304a;box-shadow:0 4px 12px rgba(232,48,74,.30);">
                <i class="fa fa-trash"></i> YES, DELETE
            </button>
            <a href="@Url.Action("Index", "Invoices")" class="btn-back" style="margin-left:10px;">
                Cancel
            </a>
        </div>
    }
</div>
