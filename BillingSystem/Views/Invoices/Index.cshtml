@model BillingSystem.Models.InvoiceIndexViewModel

@{
    ViewBag.Title = "Invoices";
}

<div class="page-header-section">
    <div>
        <a class="btn-create" href="@Url.Action("Create", "Invoices")">
            <i class="fa fa-plus"></i> CREATE NEW
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Invoices</div>
        <h1 class="page-title"><span>Review</span> invoices in Billing System</h1>
    </div>
    <div class="header-spacer"></div>
</div>

@using (Html.BeginForm("Index", "Invoices", FormMethod.Get))
{
    <div class="filter-card">
        <div class="filter-field">
            <label>Invoice Number</label>
            @Html.TextBoxFor(m => m.InvoiceNumber, new { placeholder = "INV-001" })
        </div>
        <div class="filter-field">
            <label>Customer Name</label>
            @Html.TextBoxFor(m => m.CustomerName, new { placeholder = "Customer name" })
        </div>
        <div class="filter-field">
            <label>Date From</label>
            @Html.TextBoxFor(m => m.DateFrom, "{0:yyyy-MM-dd}", new { type = "date" })
        </div>
        <div class="filter-field">
            <label>Date To</label>
            @Html.TextBoxFor(m => m.DateTo, "{0:yyyy-MM-dd}", new { type = "date" })
        </div>
        <div class="filter-field filter-field--small">
            <label>Total Amount</label>
            @Html.TextBoxFor(m => m.TotalAmount, new { type = "number", step = "0.01", placeholder = "0.00" })
        </div>
 
        <div class="filter-actions">
            <button type="submit" class="btn-filter-action" title="Search">
                <i class="fa fa-search"></i>
            </button>
            <a href="@Url.Action("Index", "Invoices")" class="btn-filter-action btn-filter-reset" title="Reset">
                <i class="fa fa-rotate-right"></i>
            </a>
        </div>
    </div>
}

<div class="page-search-wrap">
    <input id="pageSearch" type="text" placeholder="Page search:" />
</div>

<div class="table-card">
    <table>
        <thead>
            <tr>
                @*<th>Invoice Id</th>*@
                <th>Invoice Number</th>
                <th>Invoice Date</th>
                <th>Customer Name</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Invoices != null && Model.Invoices.Any())
            {
                foreach (var item in Model.Invoices)
                {
                    <tr>
                        @*<td><strong>@item.InvoiceId</strong></td>*@
                        <td>@item.InvoiceNumber</td>
                        <td>@item.InvoiceDate.ToString("MMM dd, yyyy HH:mm")</td>
                        <td>@item.CustomerName</td>
                        <td>@String.Format("{0:C}", item.TotalAmount)</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactive</span>
                            }
                        </td>
                        <td class="text-center">
                            <a class="action-btn action-view"
                               href="@Url.Action("Details", "Invoices", new { id = item.InvoiceId })"
                               title="Details">
                                <i class="fa fa-eye"></i>
                            </a>
                            <a class="action-btn action-edit"
                               href="@Url.Action("Edit", "Invoices", new { id = item.InvoiceId })"
                               title="Edit">
                                <i class="fa fa-pen"></i>
                            </a>
                            @using (Html.BeginForm("Delete", "Invoices", FormMethod.Post,
                                new { @class = "inline-form", onsubmit = "return confirm('Are you sure you want to delete this invoice?');" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("id", item.InvoiceId)
                                <button type="submit" class="action-btn action-delete" title="Delete">
                                    <i class="fa fa-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="no-data-cell">
                        <i class="fa fa-file-invoice no-data-icon"></i>
                        No invoices found.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @{
        Func<int, string> pageUrl = p => Url.Action("Index", new
        {
            page = p,
            pageSize = Model.PageSize,
            invoiceNumber = Model.InvoiceNumber,
            customerName = Model.CustomerName,
            dateFrom = Model.DateFrom?.ToString("yyyy-MM-dd"),
            dateTo = Model.DateTo?.ToString("yyyy-MM-dd"),
            minTotal = Model.TotalAmount
        });
    }

    <div class="pagination-wrap">
        <a class="page-btn @(Model.Page <= 1 ? "disabled" : "")" href="@(Model.Page > 1 ? pageUrl(1) : "#")">
            <i class="fa fa-angles-left"></i>
        </a>
        <a class="page-btn @(Model.Page <= 1 ? "disabled" : "")" href="@(Model.Page > 1 ? pageUrl(Model.Page - 1) : "#")">
            <i class="fa fa-angle-left"></i>
        </a>
        @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
        {
            <a class="page-btn @(p == Model.Page ? "active" : "")" href="@pageUrl(p)">@p</a>
        }
        <a class="page-btn @(Model.Page >= Model.TotalPages ? "disabled" : "")" href="@(Model.Page < Model.TotalPages ? pageUrl(Model.Page + 1) : "#")">
            <i class="fa fa-angle-right"></i>
        </a>
        <a class="page-btn @(Model.Page >= Model.TotalPages ? "disabled" : "")" href="@(Model.Page < Model.TotalPages ? pageUrl(Model.TotalPages) : "#")">
            <i class="fa fa-angles-right"></i>
        </a>
    </div>
    <p style="text-align:center;color:var(--muted);font-size:13px;padding:8px 0 14px;">
        Page @Model.Page of @(Model.TotalPages == 0 ? 1 : Model.TotalPages) &mdash; @Model.TotalCount record(s)
    </p>
</div>

<script>document.getElementById('pageSearch').addEventListener('input', function () {
        var v = this.value.toLowerCase();
        document.querySelectorAll('.table-card tbody tr').forEach(function (r) {
            r.style.display = r.textContent.toLowerCase().includes(v) ? '' : 'none';
        });
    });</script>
