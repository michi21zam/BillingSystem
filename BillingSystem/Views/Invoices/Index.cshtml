@model BillingSystem.Models.InvoiceIndexViewModel

@{
    ViewBag.Title = "Invoices";
}

<style>
    /* Small view-specific tweaks to make table and filters look cleaner */
    .invoice-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem; }
    .filter-toggle { cursor:pointer; }
    .filter-card { transition:all .2s ease; }
    .table-actions .btn { margin-right: .25rem; }
    @@media (max-width: 576px) {
        .form-row .form-group { margin-bottom: .5rem; }
    }
</style>

<div class="row align-items-center mb-3">
    <div class="col-md-3 text-left">
        <a class="btn btn-success btn-lg" href="@Url.Action("Create", "Invoices")"><i class="fa fa-plus mr-2"></i>CREATE NEW</a>
    </div>
    <div class="col-md-6 text-center">
        <h2 class="mb-0">Companies</h2>
        <div style="font-size:28px; color:#1b5f66; font-weight:700;">Review <span style="color:#6b6b6b; font-weight:400;">companies in Billing System</span></div>
    </div>
    <div class="col-md-3 text-right">
        <span class="badge badge-primary">@Model.TotalCount</span>
    </div>
</div>

<div class="position-relative mb-3">
    <div class="card filter-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Filters</strong>
            <small class="filter-toggle text-primary" data-toggle="collapse" data-target="#filterBody" aria-expanded="true" aria-controls="filterBody">Show / Hide</small>
        </div>
        <div id="filterBody" class="collapse show">
            <div class="card-body">
                @using (Html.BeginForm("Index", "Invoices", FormMethod.Get, new { @class = "" }))
                {
                    <div class="form-row align-items-end">
                        <div class="form-group col-md-2">
                            <label for="InvoiceNumber">Id</label>
                            @Html.TextBoxFor(m => m.InvoiceNumber, new { @class = "form-control", placeholder = "Id" })
                        </div>
                        <div class="form-group col-md-3">
                            <label for="CustomerName">Name</label>
                            @Html.TextBoxFor(m => m.CustomerName, new { @class = "form-control", placeholder = "Name" })
                        </div>
                        <div class="form-group col-md-2">
                            <label for="DateFrom">Status</label>
                            <select class="form-control"><option>All</option></select>
                        </div>
                        <div class="form-group col-md-2">
                            <label for="DateTo">Country</label>
                            <select class="form-control"><option>All</option></select>
                        </div>
                        <div class="form-group col-md-1 text-right">
                            <button type="submit" class="btn btn-primary btn-block">Filter</button>
                        </div>
                        <div class="form-group col-md-1 text-right">
                            <a href="@Url.Action("Index", "Invoices")" class="btn btn-outline-secondary btn-block">Reset</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="filter-actions d-none d-md-block">
        <button class="btn" title="Search"><i class="fa fa-search fa-lg"></i></button>
        <button class="btn" title="Reset"><i class="fa fa-rotate fa-lg"></i></button>
    </div>
</div>

<div class="page-search">
    <input class="form-control" placeholder="Page search:" />
</div>

<div class="table-wrapper mb-3">
    <div class="table-responsive">
    <table class="table table-hover table-sm">
        <thead class="thead-light">
            <tr>
                <th style="width:12%">Invoice #</th>
                <th style="width:18%">Invoice Date</th>
                <th>Customer</th>
                <th style="width:12%" class="text-right">Total</th>
                <th style="width:20%" class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Invoices != null && Model.Invoices.Any())
            {
                foreach (var item in Model.Invoices)
                {
                    <tr>
                        <td class="align-middle">@Html.DisplayFor(_ => item.InvoiceNumber)</td>
                        <td class="align-middle">@Html.DisplayFor(_ => item.InvoiceDate)</td>
                        <td class="align-middle">@Html.DisplayFor(_ => item.CustomerName)</td>
                        <td class="align-middle text-center">
                            @if (item.GetType().GetProperty("Status") != null)
                            {
                                var status = item.GetType().GetProperty("Status").GetValue(item, null)?.ToString();
                                if (!string.IsNullOrEmpty(status))
                                {
                                    <span class="badge-status">@status</span>
                                }
                            }
                        </td>
                        <td class="align-middle text-right">@String.Format("{0:C}", item.TotalAmount)</td>
                        <td class="align-middle text-center table-actions">
                            <a class="action-circle action-edit" href="@Url.Action("Edit", "Invoices", new { id = item.InvoiceId })" title="Edit"><i class="fa fa-pen"></i></a>
                            @using (Html.BeginForm("Delete", "Invoices", FormMethod.Post, new { @class = "action-form", onsubmit = "return confirm('Are you sure?');" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("id", item.InvoiceId)
                                <button type="submit" class="action-circle action-delete" title="Delete"><i class="fa fa-trash"></i></button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">No invoices found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var start = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var end = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

<div class="d-flex justify-content-between align-items-center">
    <div class="text-muted">Showing <strong>@start</strong> to <strong>@end</strong> of <strong>@Model.TotalCount</strong> invoices</div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = Model.Page - 1, pageSize = Model.PageSize, invoiceNumber = Model.InvoiceNumber, customerName = Model.CustomerName, dateFrom = Model.DateFrom?.ToString("yyyy-MM-dd"), dateTo = Model.DateTo?.ToString("yyyy-MM-dd"), minTotal = Model.MinTotal, maxTotal = Model.MaxTotal })">&laquo; Prev</a>
                </li>

                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    // Show all pages but collapse if too many could be improved later
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = p, pageSize = Model.PageSize, invoiceNumber = Model.InvoiceNumber, customerName = Model.CustomerName, dateFrom = Model.DateFrom?.ToString("yyyy-MM-dd"), dateTo = Model.DateTo?.ToString("yyyy-MM-dd"), minTotal = Model.MinTotal, maxTotal = Model.MaxTotal })">@p</a>
                    </li>
                }

                <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = Model.Page + 1, pageSize = Model.PageSize, invoiceNumber = Model.InvoiceNumber, customerName = Model.CustomerName, dateFrom = Model.DateFrom?.ToString("yyyy-MM-dd"), dateTo = Model.DateTo?.ToString("yyyy-MM-dd"), minTotal = Model.MinTotal, maxTotal = Model.MaxTotal })">Next &raquo;</a>
                </li>
            </ul>
        </nav>
    }
</div>
