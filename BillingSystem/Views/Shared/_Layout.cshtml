<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Billing System</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="~/Scripts/modernizr-2.6.2.js"></script>
</head>
<body>

    <nav class="navbar navbar-inverse navbar-fixed-top">
        <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;height:60px;padding:0 24px;width:100%;">
            <a class="navbar-brand" href="@Url.Action("Index","Invoices")">
                <i class="fa fa-file-invoice-dollar" style="color:var(--teal);margin-right:8px;"></i>BillingSystem
            </a>
            <ul style="margin:0 0 0 32px;display:flex;list-style:none;gap:4px;padding:0;">
                <li>
                    <a href="@Url.Action("Index","Invoices")"
                       style="padding:8px 14px;border-radius:8px;font-weight:600;font-size:14px;color:var(--text);text-decoration:none;transition:color .2s;"
                       onmouseover="this.style.color='var(--teal)'" onmouseout="this.style.color='var(--text)'">
                        <i class="fa fa-file-invoice" style="margin-right:6px;"></i>Invoices
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <footer>
            <p>&copy; @DateTime.Now.Year &mdash; Billing System &mdash; All rights reserved</p>
        </footer>
    </div>

    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
</body>
</html>
